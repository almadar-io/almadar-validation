{
  "name": "@almadar/validation",
  "version": "2.1.0",
  "description": "Schema validation rules for Almadar",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./error-codes": {
      "import": "./dist/error-codes.js",
      "types": "./dist/error-codes.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "eslint": "10.0.0",
    "@typescript-eslint/parser": "8.56.0",
    "@almadar/eslint-plugin": ">=2.5.0",
    "@types/node": "^22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/almadar-io/almadar.git",
    "directory": "docs/packages/validation"
  },
  "license": "MIT",
  "keywords": [
    "almadar",
    "validation",
    "schema"
  ],
  "homepage": "https://github.com/almadar-io/almadar#readme"
}
